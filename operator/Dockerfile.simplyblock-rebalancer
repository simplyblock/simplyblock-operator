# Dockerfile for the simplyblock-rebalancer NVMe-oF latency benchmark binary.
#
# The container is launched in two roles by the operator:
#   1. Privileged Kubernetes Job  — one-shot baseline measurement per storage node
#                                   (simplyblock-rebalancer --mode=baseline)
#   2. Injected sidecar           — continuous per-node latency probe, exposes
#                                   Prometheus /metrics directly
#                                   (simplyblock-rebalancer --mode=probe)
#
# Required tools:
#   simplyblock-rebalancer — Go binary built from cmd/simplyblock-rebalancer; handles NVMe connect/measure/metrics
#   fio                    — I/O benchmark backend (libaio engine, raw block device)
#   nvme-cli               — NVMe-oF connect/list/disconnect over TCP (called by simplyblock-rebalancer)
#
# Base image: Red Hat UBI 10 (required for Red Hat container certification).
# fio is sourced from EPEL / Oracle Linux 10 repos; nvme-cli is in RHEL 10 BaseOS.

FROM --platform=$BUILDPLATFORM golang:1.26 AS builder
ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace

# atlas sibling module (consumed via ../atlas-lib replace); build context is the repo
# root, so it lives next to the operator module. Copy only its manifests before
# go mod download: the download needs atlas-lib's go.mod/go.sum for the module graph,
# not its source (local-path replacements are never downloaded). Copying the full tree
# here would invalidate the download layer on any atlas-lib source change.
COPY atlas-lib/go.mod atlas-lib/go.sum /atlas-lib/

COPY operator/go.mod operator/go.sum ./
RUN go mod download

# Copy the full sources (operator + the atlas-lib tree resolved by the replace directive).
COPY atlas-lib/ /atlas-lib/
COPY operator/ .

# CGO disabled — simplyblock-rebalancer has no CGO dependencies.
RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH} \
    go build -a -o simplyblock-rebalancer ./cmd/simplyblock-rebalancer

FROM registry.access.redhat.com/ubi10/ubi:10.2

ARG VERSION=0.1.0
ARG RELEASE=1
ARG TARGETPLATFORM

RUN if [ "$TARGETPLATFORM" = "linux/arm64" ]; then \
        echo "ARM64 version"; \
        dnf install -y https://yum.oracle.com/repo/OracleLinux/OL10/baseos/latest/aarch64/getPackage/oraclelinux-release-el10-1.0-17.el10.aarch64.rpm ; \
    else \
        echo "AMD64 version"; \
        dnf install -y https://yum.oracle.com/repo/OracleLinux/OL10/baseos/latest/x86_64/getPackage/oraclelinux-release-el10-1.0-17.el10.x86_64.rpm ; \
    fi

RUN dnf update -y --nogpgcheck && \
    dnf install -y --nodocs \
        fio \
        nvme-cli \
        sudo \
    && dnf clean all

COPY --from=builder /workspace/simplyblock-rebalancer /usr/local/bin/simplyblock-rebalancer

# Run as non-root (uid 65532, gid 0) to satisfy OpenShift SCC and Red Hat
# certification requirements. sudo grants nvme-cli and fio the kernel-level
# access they require (NVMe-fabrics, raw block devices).
RUN groupadd --gid 65532 nonroot \
    && useradd --uid 65532 --gid 65532 --no-create-home --shell /sbin/nologin nonroot \
    && echo "ALL ALL=(root) NOPASSWD: /usr/sbin/nvme, /usr/bin/fio" \
        > /etc/sudoers.d/simplyblock-rebalancer \
    && chmod 0440 /etc/sudoers.d/simplyblock-rebalancer

USER 65532:65532

ENTRYPOINT ["/usr/local/bin/simplyblock-rebalancer"]

LABEL name="simplyblock-rebalancer" \
      vendor="Simplyblock" \
      maintainer="developers@simplyblock.io" \
      version="${VERSION}" \
      release="${RELEASE}" \
      summary="simplyblock-rebalancer: NVMe-oF latency benchmark for the Simplyblock Operator." \
      description="Provides simplyblock-rebalancer (Go), fio, and nvme-cli for NVMe-oF write latency benchmarking. Used by the Simplyblock Operator as a one-shot baseline Job and as a continuously-running sidecar probe that exposes Prometheus metrics directly."
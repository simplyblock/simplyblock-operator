{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "enum": ["openshift", "cert-manager"] },
        "mutual_enabled": { "type": "boolean" },
        "cert-manager": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "createSelfSignedIssuer": { "type": "boolean" },
            "cluster-issuer": { "type": "string" },
            "namespace": { "type": "string" }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": {
            "required": ["provider"]
          }
        },
        {
          "if": {
            "properties": {
              "enabled": { "const": true },
              "provider": { "const": "cert-manager" }
            },
            "required": ["enabled", "provider"]
          },
          "then": {
            "required": ["cert-manager"],
            "properties": {
              "cert-manager": {
                "required": ["cluster-issuer"],
                "properties": {
                  "cluster-issuer": { "minLength": 1 }
                }
              }
            }
          },
          "else": {
            "properties": {
              "mutual_enabled": { "const": false }
            }
          }
        }
      ]
    }
  }
}
